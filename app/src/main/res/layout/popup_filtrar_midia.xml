<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="330dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="20dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="28dp"
    app:cardElevation="12dp"
    app:strokeWidth="0dp">

    <!-- ===================================================== -->
    <!-- CONTEÚDO -->
    <!-- ===================================================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_filtrar_midia"
            android:textColor="@color/biblio_blue"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- ================================================= -->
        <!-- INPUT TÍTULO -->
        <!-- ================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">

            <EditText
                android:id="@+id/editFiltroTitulo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="@string/hint_nome_titulo"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/black"
                android:textColorHint="#8A8A8A"
                android:textSize="15sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- INPUT AUTOR -->
        <!-- ================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">

            <EditText
                android:id="@+id/editFiltroAutor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="@string/hint_nome_autor"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/black"
                android:textColorHint="#8A8A8A"
                android:textSize="15sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- INPUT ISBN -->
        <!-- ================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#EEEEEE">

            <EditText
                android:id="@+id/editFiltroIsbn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="@string/hint_isbn"
                android:inputType="number"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:textColor="@color/black"
                android:textColorHint="#8A8A8A"
                android:textSize="15sp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- BOTÃO SALVAR (Primary Pill) -->
        <!-- ================================================= -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarFiltro"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="@string/btn_salvar_filtro"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp" />

        <!-- ================================================= -->
        <!-- BOTÃO LIMPAR (Secondary Outlined/Light) -->
        <!-- ================================================= -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimparFiltro"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_limpar_filtragem"
            android:textAllCaps="false"
            android:textColor="@color/biblio_blue"
            android:textSize="15sp"
            android:textStyle="bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/white"
            app:strokeColor="@color/biblio_blue"
            app:strokeWidth="2dp"
            app:cornerRadius="24dp"
            app:elevation="0dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
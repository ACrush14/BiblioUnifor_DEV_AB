<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_popup_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- TÍTULO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOCALIZAÇÃO"
        android:textColor="@color/biblio_blue"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- SETOR EM DESTAQUE -->
    <TextView
        android:id="@+id/textSetorLocalizado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="SETOR X"
        android:textColor="@color/biblio_blue"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- MENSAGEM -->
    <TextView
        android:id="@+id/textLivroSetor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Livro: O Alienista"
        android:textColor="#415E5E"
        android:textSize="17sp" />

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonVoltarSetor"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Entendido"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="0dp" />

</LinearLayout>
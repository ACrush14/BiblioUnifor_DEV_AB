<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/biblio_bg"
    android:paddingHorizontal="24dp"
    android:paddingTop="30dp"
    android:paddingBottom="24dp">

    <!-- CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPopupPermissao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="22dp"
            android:paddingTop="26dp"
            android:paddingBottom="22dp">

            <!-- TEXTO -->
            <TextView
                android:id="@+id/textTituloPermissao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Mudar permissão de usuário para ADM?"
                android:textColor="@color/biblio_blue"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- BOTÃO -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonMudarPermissao"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="26dp"
                android:text="Mudar para ADM"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="10dp"
                app:elevation="3dp" />

            <!-- CANCELAR -->
            <TextView
                android:id="@+id/textCancelarPermissao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Cancelar"
                android:textColor="@color/biblio_blue"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
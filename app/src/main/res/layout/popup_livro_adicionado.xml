<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="32dp"
    android:paddingVertical="44dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/textTituloLivroAdicionado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Livro adicionado\ncom sucesso!"
        android:textColor="@color/biblio_blue"
        android:textSize="22sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp" />

    <!-- MENSAGEM -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Sua solicitação de aluguel foi enviada para o bibliotecário."
        android:textColor="#888888"
        android:textSize="14sp" />

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonVerMeusLivros"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Ver meus livros"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="0dp" />

</LinearLayout>

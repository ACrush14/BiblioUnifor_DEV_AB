<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#D1D1D1" />

    <TextView
        android:id="@+id/textTituloBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Opções de Leitura"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/biblio_dark"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textAutorBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Autor do Livro"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp" />

    <!-- Opção PDF -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAbrirPdf"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Ler em PDF"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:textColor="@color/biblio_dark"
        app:icon="@drawable/ic_launcher_foreground"
        app:iconTint="@color/biblio_blue" />

    <!-- Opção Audiobook -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAbrirAudiobook"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Ouvir Audiobook"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:textColor="@color/biblio_dark"
        app:icon="@drawable/ic_launcher_foreground"
        app:iconTint="@color/biblio_blue" />

    <!-- Opção Braille -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSolicitarBraille"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Solicitar Impressão em Braille"
        android:gravity="center_vertical|start"
        android:paddingStart="16dp"
        android:textColor="@color/biblio_dark"
        app:icon="@drawable/ic_launcher_foreground"
        app:iconTint="@color/biblio_blue" />

    <!-- Opção Alugar Físico -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAlugarFisico"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Alugar Livro Físico"
        android:backgroundTint="@color/biblio_blue"
        app:cornerRadius="12dp" />

</LinearLayout>

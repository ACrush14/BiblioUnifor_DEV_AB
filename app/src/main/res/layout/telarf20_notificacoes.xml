<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER PREMIUM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerNotificacoes"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ELEMENTO DECORATIVO (CÍRCULO) -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-120dp"
            android:layout_marginTop="-120dp"
            android:alpha="0.15"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO DE PERFIL ELEVADA -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoPerfilNotif"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imagePerfilNotif"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder"
                android:contentDescription="@string/content_desc_foto_perfil" />

        </androidx.cardview.widget.CardView>

        <!-- NOME DO USUÁRIO -->
        <TextView
            android:id="@+id/textNomeNotif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/nome_usuario"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFotoPerfilNotif" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SEÇÃO DE TÍTULO (Standard Padding 32dp) -->
    <LinearLayout
        android:id="@+id/layoutTituloNotif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerNotificacoes">

        <TextView
            android:id="@+id/textTituloNotif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_notificacoes"
            android:textColor="@color/biblio_dark"
            android:textSize="26sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iconBellNotif"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="@color/biblio_dark" />

    </LinearLayout>

    <!-- LISTA DE NOTIFICAÇÕES — RecyclerView com Swipe-to-Dismiss -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewNotificacoes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toTopOf="@id/barraUsuario"
        app:layout_constraintTop_toBottomOf="@id/layoutTituloNotif" />

    <!-- EMPTY STATE — exibido quando não há notificações -->
    <TextView
        android:id="@+id/tvNenhumaNotificacao"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:padding="40dp"
        android:text="@string/msg_sem_notificacoes"
        android:textColor="@color/biblio_blue"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/barraUsuario"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTituloNotif" />

    <include
        android:id="@+id/barraUsuario"
        layout="@layout/barra_tarefas_usuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerPesquisaResultado"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPerfil"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imagePerfilPesquisaResultado"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/textTituloPesquisaResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Vamos procurar"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardPerfil" />

        <TextView
            android:id="@+id/textBemVindoPesquisaResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Bem-vindo ao acervo"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textTituloPesquisaResultado" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerPesquisaResultado"
        app:layout_constraintBottom_toBottomOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input">

            <EditText
                android:id="@+id/editPesquisarLivroResultado"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toStartOf="@+id/iconFiltroResultado"
                android:background="@android:color/transparent"
                android:hint="Pesquise por título ou autor"
                android:paddingStart="20dp"
                android:paddingEnd="8dp"
                android:textColor="#444444"
                android:textColorHint="#999999"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iconFiltroResultado"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/biblio_blue" />

        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonProcurarResultado"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="Procurar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="2dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewResultados"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            tools:listitem="@layout/item_book_card" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
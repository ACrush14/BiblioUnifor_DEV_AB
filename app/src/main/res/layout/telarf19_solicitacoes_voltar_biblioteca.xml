<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/biblio_bg"
    android:paddingHorizontal="32dp"
    android:paddingTop="40dp"
    android:paddingBottom="32dp">

    <!-- TEXTO (Aesthetic typography) -->
    <TextView
        android:id="@+id/textPopupSolicitacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Solicitação feita para a biblioteca.\n\nVocê será notificado quando estiver pronto.\nAguarde x dias"
        android:textColor="@color/biblio_blue"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- BOTÃO (Pill Standard 56dp) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonPopupOkSolicitacao"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Ok"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="4dp" />

</LinearLayout>